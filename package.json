{
  "name": "spotme",
  "version": "2.0.0",
  "description": "SpotMe — gym mode for agentic coding. Works with OpenCode, Pi, and Claude Code.",
  "author": {
    "name": "bge-kernel-panic"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "spotme": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./opencode": "./dist/opencode.js",
    "./claude-mcp": "./dist/claude-mcp.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bge-kernel-panic/spotme.git"
  },
  "scripts": {
    "build": "bun build src/index.ts src/opencode.ts --outdir dist --target bun && bun build src/cli.ts src/claude-mcp.ts --outdir dist --target node",
    "build:node": "bun build src/cli.ts src/claude-mcp.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "bun test"
  },
  "keywords": [
    "pi-package",
    "opencode-plugin",
    "spotme",
    "gym-mode",
    "coding-agent"
  ],
  "pi": {
    "extensions": [
      "./src/pi.ts"
    ],
    "skills": [
      "."
    ]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@opencode-ai/plugin": "^1.14.0",
    "@sinclair/typebox": "^0.34.0",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "8.47.0",
    "@typescript-eslint/parser": "8.47.0",
    "backlog.md": "^1.45.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.47.0"
  }
}
